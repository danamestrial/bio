---
interface NavItem {
  id: string;
  label: string;
}
interface Props {
  name: string;
  items: NavItem[];
}
const { name, items } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/80 backdrop-blur">
  <nav
    class="mx-auto flex max-w-4xl items-center gap-4 px-6 py-3"
    aria-label="Primary"
  >
    <a href="#top" class="shrink-0 font-display font-semibold tracking-tight hover:text-accent">
      {name}
    </a>
    <ul class="flex flex-1 gap-1 overflow-x-auto whitespace-nowrap [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {
        items.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              data-nav={item.id}
              class="rounded-md px-3 py-1.5 text-sm text-muted transition-colors hover:text-fg aria-[current=true]:text-accent"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  // Scroll-spy: mark the link whose section is currently in view as aria-current.
  const links = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll<HTMLAnchorElement>('[data-nav]').forEach((a) =>
    links.set(a.dataset.nav!, a)
  );

  const setCurrent = (id: string) => {
    for (const [key, a] of links) {
      a.setAttribute('aria-current', String(key === id));
    }
  };

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) setCurrent(entry.target.id);
        }
      },
      // Trigger when a section crosses the upper third of the viewport.
      { rootMargin: '-20% 0px -75% 0px' }
    );
    links.forEach((_, id) => {
      const section = document.getElementById(id);
      if (section) io.observe(section);
    });
  }
</script>
