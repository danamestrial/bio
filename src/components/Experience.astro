---
import Section from './Section.astro';
import type { Profile } from '../types/profile';

interface Props {
  experience: Profile['experience'];
}
const { experience } = Astro.props;
---

<Section id="experience" index="02" title="Experience">
  <ol class="relative ml-3 border-l border-border">
    {
      experience.map((job, i) => (
        <li class="reveal relative pb-12 pl-8 last:pb-0" style={`--reveal-delay: ${i * 80}ms`}>
          <span
            class="absolute -left-[6.5px] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-bg"
            aria-hidden="true"
          />
          <article>
            <h3 class="font-display text-xl font-semibold">{job.company}</h3>
            <p class="mt-0.5 text-sm text-muted">{job.location}</p>

            <ul class="mt-3 space-y-1.5">
              {job.roles.map((role) => (
                <li class="flex flex-wrap items-baseline gap-x-3">
                  <h4 class="font-medium">{role.title}</h4>
                  <time class="font-mono text-xs uppercase tracking-wide text-accent" datetime={role.start}>
                    {role.period}
                  </time>
                </li>
              ))}
            </ul>

            <p class="mt-4 max-w-2xl leading-relaxed text-fg/90">{job.summary}</p>

            <ul class="mt-4 flex flex-wrap gap-2" aria-label="Skills used">
              {job.skills.map((skill) => (
                <li class="rounded-md bg-surface-2 px-2.5 py-1 font-mono text-xs text-muted">
                  {skill}
                </li>
              ))}
            </ul>
          </article>
        </li>
      ))
    }
  </ol>
</Section>
