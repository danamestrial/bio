---
import { execSync } from 'node:child_process';

// All resolved at build time → fully static, no client API calls.
const repo = process.env.GITHUB_REPOSITORY ?? 'danamestrial/bio';
const server = process.env.GITHUB_SERVER_URL ?? 'https://github.com';
const repoUrl = `${server}/${repo}`;

// Prefer the CI-provided SHA; fall back to local git for `npm run build`.
let sha = process.env.GITHUB_SHA ?? '';
if (!sha) {
  try {
    sha = execSync('git rev-parse HEAD', { stdio: ['ignore', 'pipe', 'ignore'] })
      .toString()
      .trim();
  } catch {
    /* not a git checkout — show repo link without a commit */
  }
}
const shortSha = sha ? sha.slice(0, 7) : null;
const commitUrl = shortSha ? `${repoUrl}/commit/${sha}` : repoUrl;

const deployedAt = new Date().toISOString().slice(0, 10);
---

<p class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs text-muted">
  <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
  <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
    Source
  </a>
  <span aria-hidden="true">·</span>
  <span>Deployed <time datetime={deployedAt}>{deployedAt}</time></span>
  {
    shortSha && (
      <>
        <span aria-hidden="true">·</span>
        <a href={commitUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
          {shortSha} ↗
        </a>
      </>
    )
  }
</p>
