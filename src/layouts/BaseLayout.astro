---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** OG/Twitter image, relative to site root */
  image?: string;
  /** schema.org JSON-LD object injected into <head> */
  jsonLd?: Record<string, unknown>;
}

const { title, description, image = '/og.png', jsonLd } = Astro.props;

// Astro.site comes from astro.config `site`; fall back to the request origin so
// canonical/OG URLs still resolve in dev.
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" sizes="any" />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-accent focus:px-4 focus:py-2 focus:font-medium focus:text-bg"
    >
      Skip to content
    </a>

    <span id="top" aria-hidden="true"></span>
    <slot />

    <script>
      // Scroll-triggered reveal via IntersectionObserver — no animation library.
      // prefers-reduced-motion users get everything shown immediately (CSS) and
      // we skip observing entirely.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

    <script>
      // Fallback for mailto: links — some browsers/OSes (e.g. Edge with no
      // default mail app) silently do nothing. Copy the address to the
      // clipboard on click so the button is never a dead end. We don't
      // preventDefault, so a configured mail client still opens.
      const mailLinks = document.querySelectorAll<HTMLAnchorElement>('a[href^="mailto:"]');
      if (mailLinks.length && navigator.clipboard) {
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.setAttribute('role', 'status');
        document.body.appendChild(toast);
        let timer: ReturnType<typeof setTimeout>;
        mailLinks.forEach((a) =>
          a.addEventListener('click', async () => {
            const email = a.getAttribute('href')!.replace(/^mailto:/, '');
            try {
              await navigator.clipboard.writeText(email);
              toast.textContent = `Copied ${email}`;
              toast.classList.add('is-visible');
              clearTimeout(timer);
              timer = setTimeout(() => toast.classList.remove('is-visible'), 2400);
            } catch {
              /* clipboard blocked (e.g. insecure context) — mailto still fires */
            }
          })
        );
      }
    </script>
  </body>
</html>
